{
  "ignoreCommand": "[[ \"$VERCEL_GIT_COMMIT_REF\" != \"main\" && \"$VERCEL_GIT_COMMIT_REF\" != \"master\" && \"$VERCEL_ENV\" != \"preview\" ]]",
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }],
  "crons": [
    {
      "path": "/api/cron/keepalive",
      "schedule": "0 12 * * *"
    }
  ]
}
